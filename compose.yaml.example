services:
  website:
    build: ./website
    restart: always
    ports:
      - 8000:8000
    depends_on:
      - db
    environment:
      - SECRET
      - HOSTS
      - DB_PASSWORD
      - DB_USER=subterfuge
      - DB_HOST=db
      - DB_NAME=subterfuge
    volumes:
      - ./archive:/data/import:ro
  db:
    image: postgres:16
    restart: always
    environment:
      - POSTGRES_PASSWORD=${DB_PASSWORD}
      - POSTGRES_USER=subterfuge
      - POSTGRES_DB=subterfuge
    volumes:
      - ./db:/var/lib/postgresql/data
  downloader:
    build: ./downloader
    restart: always
    volumes:
      - ./archive:/data:rw